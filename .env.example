# =============================================================================
# GochitoSystem — Plantilla de variables de entorno
#
# Copia este archivo como `.env` y rellena los valores reales.
# El archivo `.env` NUNCA se sube al repositorio (esta en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# ENTORNO
# -----------------------------------------------------------------------------
NODE_ENV=development
TZ=America/Bogota

# -----------------------------------------------------------------------------
# API (backend)
# -----------------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
API_PREFIX=/api/v1
# Origenes permitidos por CORS, separados por coma
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
#
# Opcion A (recomendada para BD externa/gestionada): cadena de conexion completa.
# Si defines DATABASE_URL, tiene prioridad y las DB_* de abajo se ignoran.
#   DATABASE_URL=postgres://usuario:password@host-externo:5432/gochitosystem?sslmode=require
DATABASE_URL=
#
# Opcion B: variables discretas (para Postgres local en desarrollo).
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=gochitosystem
DB_USER=gochito
DB_PASSWORD=
# Pool de conexiones
DB_CONNECTION_LIMIT=10
DB_TIMEZONE=-05:00
# SSL: actívalo (true) para bases gestionadas externas (Neon, Supabase, RDS...).
# En local con Postgres sin TLS, déjalo en false.
DB_SSL=false
# La mayoría de proveedores usan certs que no validan contra CA pública: déjalo false.
DB_SSL_REJECT_UNAUTHORIZED=false

# -----------------------------------------------------------------------------
# SEGURIDAD / AUTENTICACION
# -----------------------------------------------------------------------------
# Genera secretos nuevos para produccion. Nunca reutilices los de desarrollo.
JWT_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12
# Limite de peticiones por ventana de tiempo
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_LOGIN_MAX=10

# -----------------------------------------------------------------------------
# ARCHIVOS Y ALMACENAMIENTO
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=5
LOGO_MAX_SIZE_MB=2

# -----------------------------------------------------------------------------
# NEGOCIO (valores por defecto; se sobrescriben desde la tabla `configuracion`)
# -----------------------------------------------------------------------------
NEGOCIO_NOMBRE=GochitoSystem
NEGOCIO_MONEDA=COP
NEGOCIO_MONEDA_SIMBOLO=$
NEGOCIO_IVA_DEFECTO=19
NEGOCIO_DECIMALES=0
NEGOCIO_REDONDEO=50

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# BACKUPS
# -----------------------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

# -----------------------------------------------------------------------------
# FRONTEND (Vite — solo variables con prefijo VITE_ llegan al navegador)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:4000/api/v1
VITE_APP_NAME=GochitoSystem
VITE_MONEDA=COP
VITE_LOCALE=es-CO
