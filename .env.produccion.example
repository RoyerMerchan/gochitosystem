# =============================================================================
# Variables de PRODUCCION para el VPS.
# Copia este archivo como  .env.produccion  y rellena los valores.
# Los valores reales estan en  secretos-produccion.txt  (no versionado).
#   cp .env.produccion.example .env.produccion   &&   nano .env.produccion
# =============================================================================

# Base de datos
DB_NAME=gochitosystem
DB_USER=gochito
DB_PASSWORD=pega-aqui-la-clave-de-secretos-produccion
DB_ROOT_PASSWORD=pega-aqui-la-clave-root-de-secretos-produccion

# Seguridad (JWT). Usa los de secretos-produccion.txt o genera nuevos.
JWT_SECRET=pega-aqui-el-jwt-secret
JWT_REFRESH_SECRET=pega-aqui-el-jwt-refresh-secret

# Puerto en el que el VPS publica la web (80 = http estandar).
WEB_PORT=80

# URL publica de la app (para CORS y enlaces). Ej: https://pos.tudominio.com
APP_URL=http://localhost
